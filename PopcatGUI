NotifyContainer.BackgroundTransparency = 1
NotifyContainer.Name = "Notifications"

local function Notify(message, duration, color)
    duration = duration or 3
    color = color or CONFIG.Accent

    local frame = Instance.new("Frame")
    frame.Parent = NotifyContainer
    frame.Size = UDim2.new(1, 0, 0, 44)
    frame.BackgroundColor3 = Color3.fromRGB(20,20,24)
    frame.BorderSizePixel = 0
    frame.Position = UDim2.new(0, 0, 0, -50)
    local corner = Instance.new("UICorner")
    corner.Parent = frame
    corner.CornerRadius = UDim.new(0, 10)
    local stroke = Instance.new("UIStroke")
    stroke.Parent = frame
    stroke.Color = color
    stroke.Thickness = 2

    local text = Instance.new("TextLabel")
    text.Parent = frame
    text.BackgroundTransparency = 1
    text.Size = UDim2.new(1, -20, 1, 0)
    text.Position = UDim2.new(0, 10, 0, 0)
    text.Text = message
    text.TextColor3 = Color3.new(1,1,1)
    text.Font = Enum.Font.Gotham
    text.TextSize = 16
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.TextYAlignment = Enum.TextYAlignment.Center
    text.TextWrapped = true

    TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
        Position = UDim2.new(0, 0, 0, 0)
    }):Play()

    -- Reorganizar
    task.wait(0.1)
    local children = NotifyContainer:GetChildren()
    for i, child in ipairs(children) do
        if child ~= frame then
            local pos = child.Position.Y.Offset
            TweenService:Create(child, TweenInfo.new(0.3), {
                Position = UDim2.new(0, 0, 0, pos + 48)
            }):Play()
        end
    end

    task.wait(duration)
    TweenService:Create(frame, TweenInfo.new(0.3), {
        Position = UDim2.new(0, 0, 0, -50),
        BackgroundTransparency = 1,
        TextTransparency = 1,
    }):Play()
    task.wait(0.4)
    frame:Destroy()

    -- Reorganizar novamente
    task.wait(0.1)
    local remaining = NotifyContainer:GetChildren()
    for i, child in ipairs(remaining) do
        if child:IsA("Frame") then
            TweenService:Create(child, TweenInfo.new(0.3), {
                Position = UDim2.new(0, 0, 0, (i-1) * 48)
            }):Play()
        end
    end
end

