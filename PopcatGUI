local NotifyContainer = Instance.new("Frame")
NotifyContainer.Parent = gui
NotifyContainer.Size = UDim2.new(0, 350, 0, 100)
NotifyContainer.Position = UDim2.new(1, -370, 0, 20)
NotifyContainer.BackgroundTransparency = 1
NotifyContainer.Name = "NotificationContainer"

local function Notify(message, duration, color)
    duration = duration or 3
    color = color or CONFIG.AccentColor

    local frame = Instance.new("Frame")
    frame.Parent = NotifyContainer
    frame.Size = UDim2.new(1, 0, 0, 40)
    frame.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    frame.BorderSizePixel = 0
    frame.Position = UDim2.new(0, 0, 0, -50)
    local frameCorner = Instance.new("UICorner")
    frameCorner.Parent = frame
    frameCorner.CornerRadius = UDim.new(0, 8)

    local stroke = Instance.new("UIStroke")
    stroke.Parent = frame
    stroke.Color = color
    stroke.Thickness = 2

    local text = Instance.new("TextLabel")
    text.Parent = frame
    text.BackgroundTransparency = 1
    text.Size = UDim2.new(1, -20, 1, 0)
    text.Position = UDim2.new(0, 10, 0, 0)
    text.Text = message
    text.TextColor3 = Color3.new(1, 1, 1)
    text.Font = Enum.Font.Gotham
    text.TextSize = 16
    text.TextXAlignment = Enum.TextXAlignment.Left
    text.TextYAlignment = Enum.TextYAlignment.Center

    -- Animar entrada
    TweenService:Create(frame, TweenInfo.new(0.4, Enum.EasingStyle.Back), {
        Position = UDim2.new(0, 0, 0, 0)
    }):Play()

    -- Ajustar a posição dos demais
    task.wait(0.1)
    for _, child in ipairs(NotifyContainer:GetChildren()) do
        if child ~= frame then
            local pos = child.Position.Y.Offset
            TweenService:Create(child, TweenInfo.new(0.3), {
                Position = UDim2.new(0, 0, 0, pos + 45)
            }):Play()
        end
    end

    -- Remover após o tempo
    task.wait(duration)
    TweenService:Create(frame, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
        Position = UDim2.new(0, 0, 0, -50),
        BackgroundTransparency = 1,
        TextTransparency = 1,
    }):Play()
    task.wait(0.4)
    frame:Destroy()

    -- Reorganizar os restantes
    local children = NotifyContainer:GetChildren()
    for i, child in ipairs(children) do
        if child:IsA("Frame") then
            TweenService:Create(child, TweenInfo.new(0.3), {
                Position = UDim2.new(0, 0, 0, (i-1) * 45)
            }):Play()
        end
    end
end

-- ============================================================
--  FUNÇÃO PARA CRIAR BOTÕES DE AÇÃO (toggles, sliders, etc.)
-- ============================================================
local function CreateToggle(parent, title, default, callback, yPos)
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = UDim2.new(0.9, 0, 0, 40)
    frame.Position = UDim2.new(0.05, 0, yPos or 0.2, 0)
    frame.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = title
    label.TextColor3 = Color3.new(1,1,1)
    label.Font = Enum.Font.Gotham
    label.TextSize = 18
    label.TextXAlignment = Enum.TextXAlignment.Left

    local toggle = Instance.new("TextButton")
    toggle.Parent = frame
    toggle.Size = UDim2.new(0, 60, 0, 30)
    toggle.Position = UDim2.new(0.85, 0, 0.125, 0)
    toggle.BackgroundColor3 = default and CONFIG.AccentColor or Color3.fromRGB(60, 60, 60)
    toggle.Text = default and "ON" or "OFF"
    toggle.TextColor3 = Color3.new(1,1,1)
    toggle.Font = Enum.Font.GothamBold
    toggle.TextSize = 14
    toggle.AutoButtonColor = false
    local togCorner = Instance.new("UICorner")
    togCorner.Parent = toggle
    togCorner.CornerRadius = UDim.new(0, 12)

    local state = default
    toggle.MouseButton1Click:Connect(function()
        state = not state
        toggle.BackgroundColor3 = state and CONFIG.AccentColor or Color3.fromRGB(60, 60, 60)
        toggle.Text = state and "ON" or "OFF"
        if callback then callback(state) end
    end)

    return toggle
end

local function CreateSlider(parent, title, min, max, default, callback, yPos)
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = UDim2.new(0.9, 0, 0, 50)
    frame.Position = UDim2.new(0.05, 0, yPos or 0.3, 0)
    frame.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(0.6, 0, 0.5, 0)
    label.BackgroundTransparency = 1
    label.Text = title
    label.TextColor3 = Color3.new(1,1,1)
    label.Font = Enum.Font.Gotham
    label.TextSize = 18
    label.TextXAlignment = Enum.TextXAlignment.Left

    local valueLabel = Instance.new("TextLabel")
    valueLabel.Parent = frame
    valueLabel.Size = UDim2.new(0.3, 0, 0.5, 0)
    valueLabel.Position = UDim2.new(0.7, 0, 0, 0)
    valueLabel.BackgroundTransparency = 1
    valueLabel.Text = tostring(default)
    valueLabel.TextColor3 = CONFIG.AccentLight
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 18
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right

    local slider = Instance.New("Frame")
    slider.Parent = frame
    slider.Size = UDim2.new(0.9, 0, 0, 6)
    slider.Position = UDim2.new(0, 0, 0.75, 0)
    slider.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    slider.BorderSizePixel = 0
    local sliderCorner = Instance.new("UICorner")
    sliderCorner.Parent = slider
    sliderCorner.CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Parent = slider
    fill.Size = UDim2.new((default - min)/(max - min), 0, 1, 0)
    fill.BackgroundColor3 = CONFIG.AccentColor
    fill.BorderSizePixel = 0
    local fillCorner = Instance.new("UICorner")
    fillCorner.Parent = fill
    fillCorner.CornerRadius = UDim.new(1, 0)

    local dragging = false
    local dragConn
    local function update(pos)
        local rel = math.clamp((pos.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
        local val = min + (max - min) * rel
        val = math.floor(val + 0.5)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        valueLabel.Text = tostring(val)
        if callback then callback(val) end
    end

    slider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input.Position)
            dragConn = UIS.InputChanged:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseMovement then
                    update(inp.Position)
                end
            end)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
            dragging = false
            if dragConn then dragConn:Disconnect(); dragConn = nil end
        end
    end)
end

