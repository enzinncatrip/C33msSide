        -- Animação de transição
        for _, child in ipairs(PagesContainer:GetChildren()) do
            if child:IsA("Frame") then
                child.Visible = false
            end
        end
        page.Visible = true
        currentPage = page
        -- Efeito de clique no botão
        TweenService:Create(btn, TweenInfo.new(0.1), {
            Size = UDim2.new(0.85,0,0,42)
        }):Play()
        task.wait(0.1)
        TweenService:Create(btn, TweenInfo.new(0.1), {
            Size = UDim2.new(0.9,0,0,45)
        }):Play()
    end)
end

-- ======================================================
--  DRAG MELHORADO
-- ======================================================
local dragData = {dragging = false, startPos = nil, startMouse = nil}
Top.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragData.dragging = true
        dragData.startPos = Main.Position
        dragData.startMouse = input.Position
    end
end)
Top.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragData.dragging = false
    end
end)
UIS.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement and dragData.dragging then
        local delta = input.Position - dragData.startMouse
        Main.Position = UDim2.new(
            dragData.startPos.X.Scale,
            dragData.startPos.X.Offset + delta.X,
            dragData.startPos.Y.Scale,
            dragData.startPos.Y.Offset + delta.Y
        )
    end
end)

-- ======================================================
--  TECLA F1
-- ======================================================
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.F1 then
        gui.Enabled = not gui.Enabled
        if gui.Enabled then
            TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
                Position = UDim2.new(0.5,-475,0.5,-290)
            }):Play()
        end
    end
end)

