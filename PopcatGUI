-- ======================================================
--  SISTEMA DE NOTIFICAÇÕES (TOASTS)
-- ======================================================
local function Notify(text, color, duration)
    color = color or Color3.fromRGB(255,80,180)
    duration = duration or 3
    local frame = Instance.new("Frame")
    frame.Parent = gui
    frame.Size = UDim2.new(0,300,0,50)
    frame.Position = UDim2.new(1,-320,1,-80)
    frame.BackgroundColor3 = color
    frame.BackgroundTransparency = 0.2
    CreateCorner(frame, UDim.new(0,8))
    local stroke = CreateStroke(frame, color, 2)
    local label = CreateLabel(frame, text, UDim2.new(1,0,1,0), nil, Color3.new(1,1,1), Enum.Font.Gotham, false)
    label.TextSize = 16
    label.TextXAlignment = Enum.TextXAlignment.Center
    frame:TweenPosition(UDim2.new(1,-320,1,-100), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.3, true)
    task.wait(duration)
    frame:TweenPosition(UDim2.new(1,-320,1,-20), Enum.EasingDirection.In, Enum.EasingStyle.Quad, 0.3, true, nil, function()
        frame:Destroy()
    end)
end

-- ======================================================
--  FUNÇÃO PARA APLICAR TEMA
-- ======================================================
function ApplyTheme(themeName)
    local colors = Themes[themeName] or Themes.Dark
    -- Atualizar cores dos elementos principais
    Main.BackgroundColor3 = colors.BG
    mainStroke.Color = colors.Stroke
    Top.BackgroundColor3 = colors.Top
    Title.TextColor3 = colors.AccentLight
    Sidebar.BackgroundColor3 = colors.Sidebar
    PagesContainer.BackgroundColor3 = colors.Page
    CloseBtn.BackgroundColor3 = colors.Close
    MinBtn.BackgroundColor3 = colors.Min
    -- Atualizar botões da sidebar
    for _, btn in ipairs(Sidebar:GetChildren()) do
        if btn:IsA("TextButton") then
            btn.BackgroundColor3 = colors.Button
            btn.TextColor3 = colors.AccentLight
        end
    end
    -- Atualizar stroke de todos os botões (pode otimizar depois)
    Notify("Tema alterado para " .. themeName, colors.Accent, 2)
end

