local function CreateESP(player)
    if not player.Character then return end
    local char = player.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    -- Criação do ESP (caixa, nome, distância)
    local box = Instance.new("BoxHandleAdornment")
    box.Parent = root
    box.Adornee = root
    box.Size = Vector3.new(4, 6, 2)
    box.Color3 = player.TeamColor and player.TeamColor.Color or Color3.new(1,1,1)
    box.Transparency = 0.5
    box.ZIndex = 0
    box.AlwaysOnTop = true

    local line = Instance.new("LineHandleAdornment")
    line.Parent = root
    line.Adornee = root
    line.Color3 = Color3.new(1,1,1)
    line.Thickness = 1
    line.Transparency = 0.5
    line.Length = 50
    line.ZIndex = 0

    local bill = Instance.new("BillboardGui")
    bill.Parent = root
    bill.Size = UDim2.new(0, 200, 0, 50)
    bill.Adornee = root
    bill.AlwaysOnTop = true
    local name = Instance.new("TextLabel")
    name.Parent = bill
    name.Size = UDim2.new(1,0,1,0)
    name.BackgroundTransparency = 1
    name.Text = player.Name .. " | " .. math.floor((root.Position - Player.Character.HumanoidRootPart.Position).Magnitude) .. "m"
    name.TextColor3 = Color3.new(1,1,1)
    name.TextScaled = true
    name.Font = Enum.Font.GothamBold

    table.insert(ESPObjects, {box, line, bill, name, player})
end

local function ClearESP()
    for _, obj in ipairs(ESPObjects) do
        for _, v in ipairs(obj) do
            if v:IsA("BasePart") and v.Parent then v:Destroy() end
        end
    end
    ESPObjects = {}
end

local function ToggleESP(state)
    ESPEnabled = state
    if state then
        ClearESP()
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= Player then CreateESP(plr) end
        end
        ESPConnections.PlayerAdded = Players.PlayerAdded:Connect(function(plr)
            plr.CharacterAdded:Connect(function() CreateESP(plr) end)
        end)
        ESPConnections.CharacterAdded = {}
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= Player then
                ESPConnections.CharacterAdded[plr] = plr.CharacterAdded:Connect(function() CreateESP(plr) end)
            end
        end
    else
        ClearESP()
        if ESPConnections.PlayerAdded then ESPConnections.PlayerAdded:Disconnect() end
        for _, conn in pairs(ESPConnections.CharacterAdded or {}) do conn:Disconnect() end
        ESPConnections = {}
    end
end

-- ============================================================
--  AIMBOT (básico)
-- ============================================================
local function AimbotLoop()
    if not AimbotEnabled then return end
    local target = nil
    local minDist = math.huge
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= Player and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
            local root = plr.Character.HumanoidRootPart
            if root then
                local pos, onScreen = Camera:WorldToScreenPoint(root.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if dist < minDist then
                        minDist = dist
                        target = root
                    end
                end
            end
        end
    end
    if target then
        local aimPos = target.Position + Vector3.new(0, 1.5, 0)
        Mouse.MoveTo(aimPos)
    end
end

-- ============================================================
--  FLY SYSTEM
-- ============================================================
local function ToggleFly(state)
    FlyEnabled = state
    if state then
        local char = Player.Character
        if not char then return end
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end
        if not FlyBodyVelocity then
            FlyBodyVelocity = Instance.new("BodyVelocity")
            FlyBodyVelocity.MaxForce = Vector3.new(1e9, 1e9, 1e9)
        end
        FlyBodyVelocity.Parent = hrp
        FlyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
        local hum = char:FindFirstChild("Humanoid")
        if hum then hum.PlatformStand = true end
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if not FlyEnabled then conn:Disconnect(); return end
            if not FlyBodyVelocity.Parent then FlyBodyVelocity.Parent = hrp end
            local move = Vector3.new()
            if UIS:IsKeyDown(Enum.KeyCode.W) then move = move + Camera.CFrame.LookVector * FlySpeed end
            if UIS:IsKeyDown(Enum.KeyCode.S) then move = move - Camera.CFrame.LookVector * FlySpeed end
            if UIS:IsKeyDown(Enum.KeyCode.A) then move = move - Camera.CFrame.RightVector * FlySpeed end
            if UIS:IsKeyDown(Enum.KeyCode.D) then move = move + Camera.CFrame.RightVector * FlySpeed end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, FlySpeed, 0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then move = move - Vector3.new(0, FlySpeed, 0) end
            FlyBodyVelocity.Velocity = move
        end)
    else
        if FlyBodyVelocity then FlyBodyVelocity:Destroy(); FlyBodyVelocity = nil end
        local char = Player.Character
        if char then
            local hum = char:FindFirstChild("Humanoid")
            if hum then hum.PlatformStand = false end
        end
    end
end

-- ============================================================
--  KILL AURA
-- ============================================================
local function ToggleKillAura(state)
    KillAuraEnabled = state
    if state then
        local conn
        conn = RunService.Heartbeat:Connect(function()
            if not KillAuraEnabled then conn:Disconnect(); return end
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= Player and plr.Character and plr.Character:FindFirstChild("Humanoid") and plr.Character.Humanoid.Health > 0 then
                    local root = plr.Character:FindFirstChild("HumanoidRootPart")
                    local myRoot = Player.Character and Player.Character:FindFirstChild("HumanoidRootPart")
                    if root and myRoot and (root.Position - myRoot.Position).Magnitude <= KillAuraRange then
                        plr.Character.Humanoid.Health = 0
                    end
                end
            end
        end)
    end
end

