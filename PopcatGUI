local function CreateToggle(parent, title, default, callback, yPos, tooltip)
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = UDim2.new(0.92, 0, 0, 44)
    frame.Position = UDim2.new(0.04, 0, yPos or 0.2, 0)
    frame.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(0.6, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = title
    label.TextColor3 = CONFIG.TextColor
    label.Font = Enum.Font.Gotham
    label.TextSize = 18
    label.TextXAlignment = Enum.TextXAlignment.Left

    local toggle = Instance.new("TextButton")
    toggle.Parent = frame
    toggle.Size = UDim2.new(0, 64, 0, 32)
    toggle.Position = UDim2.new(0.85, 0, 0.135, 0)
    toggle.BackgroundColor3 = default and CONFIG.Accent or Color3.fromRGB(60,60,68)
    toggle.Text = default and "ON" or "OFF"
    toggle.TextColor3 = Color3.new(1,1,1)
    toggle.Font = Enum.Font.GothamBold
    toggle.TextSize = 14
    toggle.AutoButtonColor = false
    local togCorner = Instance.new("UICorner")
    togCorner.Parent = toggle
    togCorner.CornerRadius = UDim.new(0, 12)

    local state = LoadSetting(title, default)
    toggle.BackgroundColor3 = state and CONFIG.Accent or Color3.fromRGB(60,60,68)
    toggle.Text = state and "ON" or "OFF"
    if callback then callback(state) end

    toggle.MouseButton1Click:Connect(function()
        state = not state
        toggle.BackgroundColor3 = state and CONFIG.Accent or Color3.fromRGB(60,60,68)
        toggle.Text = state and "ON" or "OFF"
        SaveSetting(title, state)
        if callback then callback(state) end
        Notify(title .. (state and " ✅" or " ❌"), 1.5)
    end)
    return toggle
end

local function CreateSlider(parent, title, min, max, default, callback, yPos)
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = UDim2.new(0.92, 0, 0, 54)
    frame.Position = UDim2.new(0.04, 0, yPos or 0.3, 0)
    frame.BackgroundTransparency = 1

    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(0.5, 0, 0.4, 0)
    label.BackgroundTransparency = 1
    label.Text = title
    label.TextColor3 = CONFIG.TextColor
    label.Font = Enum.Font.Gotham
    label.TextSize = 18
    label.TextXAlignment = Enum.TextXAlignment.Left

    local valueLabel = Instance.new("TextLabel")
    valueLabel.Parent = frame
    valueLabel.Size = UDim2.new(0.35, 0, 0.4, 0)
    valueLabel.Position = UDim2.new(0.6, 0, 0, 0)
    valueLabel.BackgroundTransparency = 1
    local val = LoadSetting(title, default)
    valueLabel.Text = tostring(val)
    valueLabel.TextColor3 = CONFIG.AccentLight
    valueLabel.Font = Enum.Font.GothamBold
    valueLabel.TextSize = 18
    valueLabel.TextXAlignment = Enum.TextXAlignment.Right

    local slider = Instance.new("Frame")
    slider.Parent = frame
    slider.Size = UDim2.new(0.9, 0, 0, 6)
    slider.Position = UDim2.new(0, 0, 0.75, 0)
    slider.BackgroundColor3 = Color3.fromRGB(50,50,58)
    slider.BorderSizePixel = 0
    local sliderCorner = Instance.new("UICorner")
    sliderCorner.Parent = slider
    sliderCorner.CornerRadius = UDim.new(1,0)

    local fill = Instance.new("Frame")
    fill.Parent = slider
    fill.Size = UDim2.new((val - min)/(max - min), 0, 1, 0)
    fill.BackgroundColor3 = CONFIG.Accent
    fill.BorderSizePixel = 0
    local fillCorner = Instance.new("UICorner")
    fillCorner.Parent = fill
    fillCorner.CornerRadius = UDim.new(1,0)

    local dragging = false
    local dragConn
    local function update(pos)
        local rel = math.clamp((pos.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
        local val = math.round(min + (max - min) * rel)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        valueLabel.Text = tostring(val)
        SaveSetting(title, val)
        if callback then callback(val) end
    end

    slider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input.Position)
            dragConn = UIS.InputChanged:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseMovement then
                    update(inp.Position)
                end
            end)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
            dragging = false
            if dragConn then dragConn:Disconnect(); dragConn = nil end
        end
    end)
    return valueLabel
end

