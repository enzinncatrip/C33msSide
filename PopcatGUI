local CurrentPage = nil

local function CreatePageContent(page, tabName)
    local title = CreateTextLabel(page, tabName, UDim2.new(1, 0, 0, 50), UDim2.new(0, 10, 0.05, 0), CONFIG.Colors.AccentLight, Enum.Font.GothamBlack)
    if tabName == "Home" then
        local desc = CreateTextLabel(page, "Bem-vindo ao Popcat GUI!\nClique nas abas ao lado para navegar.", 
            UDim2.new(1, -20, 0, 80), UDim2.new(0, 10, 0.15, 0), Color3.new(1, 1, 1), Enum.Font.Gotham)
        desc.TextScaled = false
        desc.TextSize = 20
        desc.TextWrapped = true
    elseif tabName == "Player" then
        local toggle = Instance.new("TextButton")
        toggle.Parent = page
        toggle.Size = UDim2.new(0, 200, 0, 40)
        toggle.Position = UDim2.new(0, 10, 0.2, 0)
        toggle.BackgroundColor3 = CONFIG.Colors.ButtonBg
        toggle.Text = "Ativar Modo Deus"
        toggle.TextColor3 = Color3.new(1, 1, 1)
        toggle.Font = Enum.Font.GothamBold
        toggle.TextScaled = true
        CreateCorner(toggle, UDim.new(0, 8))
        local stroke = CreateStroke(toggle, CONFIG.Colors.Accent, 2)
        local active = false
        toggle.MouseButton1Click:Connect(function()
            active = not active
            toggle.BackgroundColor3 = active and CONFIG.Colors.Accent or CONFIG.Colors.ButtonBg
            toggle.Text = active and "✅ Ativado" or "Ativar Modo Deus"
        end)
    end
end

for _, tabName in ipairs(CONFIG.Tabs) do
    local btn = Instance.new("TextButton")
    btn.Parent = Sidebar
    btn.Size = UDim2.new(0.9, 0, 0, 42)
    btn.BackgroundColor3 = CONFIG.Colors.ButtonBg
    btn.Text = tabName
    btn.Font = Enum.Font.GothamBold
    btn.TextScaled = true
    btn.TextColor3 = CONFIG.Colors.AccentLight
    btn.AutoButtonColor = false
    CreateCorner(btn, UDim.new(0, 8))
    local btnStroke = CreateStroke(btn, CONFIG.Colors.Accent, 2)

    local page = Instance.new("Frame")
    page.Name = tabName
    page.Parent = Pages
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.Visible = (tabName == "Home")
    if tabName == "Home" then CurrentPage = page end

    CreatePageContent(page, tabName)

    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = CONFIG.Colors.Accent
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.15), {
            BackgroundColor3 = CONFIG.Colors.ButtonBg
        }):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        for _, child in ipairs(Pages:GetChildren()) do
            if child:IsA("Frame") then
                child.Visible = false
            end
        end
        page.Visible = true
        CurrentPage = page
    end)
end

-- ======================================================
--  DRAG
-- ======================================================
local dragging = false
local dragStart, startPos, dragInput

Top.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
    end
end)

Top.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

UIS.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

-- ======================================================
--  ATALHO TECLADO
-- ======================================================
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.F1 then
        gui.Enabled = not gui.Enabled
    end
end)

