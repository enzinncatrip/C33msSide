    -- Efeitos hover
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {
            BackgroundColor3 = CONFIG.AccentColor,
            TextColor3 = Color3.new(1,1,1)
        }):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.2), {
            BackgroundColor3 = Color3.fromRGB(35, 35, 35),
            TextColor3 = CONFIG.AccentLight
        }):Play()
    end)

    -- Clique com animação de transição
    btn.MouseButton1Click:Connect(function()
        -- Animação de fade out da página atual
        if CurrentPage and CurrentPage ~= page then
            TweenService:Create(CurrentPage, TweenInfo.new(0.15), {
                BackgroundTransparency = 0.5,
                Visible = false
            }):Play()
        end
        -- Mostrar nova página com fade in
        page.Visible = true
        page.BackgroundTransparency = 0.5
        TweenService:Create(page, TweenInfo.new(0.2), {
            BackgroundTransparency = 0
        }):Play()
        CurrentPage = page
        Notify("📂 Aba: " .. tabName, 1.5)
    end)

    SidebarButtons[tabName] = btn
end

-- ============================================================
--  SISTEMA DE DRAG MELHORADO (com suporte a toque)
-- ============================================================
local drag = {
    active = false,
    startPos = nil,
    startMouse = nil,
    connection = nil
}

Top.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        drag.active = true
        drag.startPos = Main.Position
        drag.startMouse = input.Position
    end
end)

Top.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        drag.active = false
        if drag.connection then drag.connection:Disconnect(); drag.connection = nil end
    end
end)

UIS.InputChanged:Connect(function(input)
    if drag.active and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - drag.startMouse
        Main.Position = UDim2.new(
            drag.startPos.X.Scale,
            drag.startPos.X.Offset + delta.X,
            drag.startPos.Y.Scale,
            drag.startPos.Y.Offset + delta.Y
        )
    end
end)

-- ============================================================
--  TECLA F1 PARA ABRIR/FECHAR COM ANIMAÇÃO
-- ============================================================
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == CONFIG.ToggleKey then
        gui.Enabled = not gui.Enabled
        if gui.Enabled then
            TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Back), {
                Position = UDim2.new(0.5, -CONFIG.WindowSize.Width/2, 0.5, -CONFIG.WindowSize.Height/2)
            }):Play()
            Notify("🐱 GUI reaberta!", 1.5)
        else
            Notify("👋 GUI fechada (F1 para abrir)", 1.5)
        end
    end
end)

