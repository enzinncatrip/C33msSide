-- ======================================================
--  FUNÇÕES AUXILIARES
-- ======================================================
local function CreateCorner(instance, radius)
    local corner = Instance.new("UICorner")
    corner.Parent = instance
    corner.CornerRadius = radius or UDim.new(0, 12)
    return corner
end

local function CreateStroke(instance, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Parent = instance
    stroke.Color = color or CONFIG.Colors.Accent
    stroke.Thickness = thickness or 3
    return stroke
end

local function CreateTextLabel(parent, text, size, position, color, font, scalemode)
    local label = Instance.new("TextLabel")
    label.Parent = parent
    label.BackgroundTransparency = 1
    label.Size = size or UDim2.new(1, 0, 1, 0)
    label.Position = position or UDim2.new(0, 0, 0, 0)
    label.Text = text or ""
    label.Font = font or Enum.Font.GothamBold
    label.TextScaled = scalemode or true
    label.TextColor3 = color or Color3.new(1, 1, 1)
    return label
end

