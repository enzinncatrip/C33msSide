local function CreateSlider(parent, title, min, max, default, callback, yPos)
    local frame = Instance.new("Frame")
    frame.Parent = parent
    frame.Size = UDim2.new(0.9, 0, 0, 50)
    frame.Position = UDim2.new(0.05, 0, yPos or 0.3, 0)
    frame.BackgroundTransparency = 1
    local label = Instance.new("TextLabel")
    label.Parent = frame
    label.Size = UDim2.new(0.6, 0, 0.5, 0)
    label.BackgroundTransparency = 1
    label.Text = title
    label.TextColor3 = CONFIG.TextColor
    label.Font = Enum.Font.Gotham
    label.TextSize = 18
    label.TextXAlignment = Enum.TextXAlignment.Left
    local valLabel = Instance.new("TextLabel")
    valLabel.Parent = frame
    valLabel.Size = UDim2.new(0.3, 0, 0.5, 0)
    valLabel.Position = UDim2.new(0.7, 0, 0, 0)
    valLabel.BackgroundTransparency = 1
    valLabel.Text = tostring(default)
    valLabel.TextColor3 = CONFIG.AccentLight
    valLabel.Font = Enum.Font.GothamBold
    valLabel.TextSize = 18
    valLabel.TextXAlignment = Enum.TextXAlignment.Right
    local slider = Instance.new("Frame")
    slider.Parent = frame
    slider.Size = UDim2.new(0.9, 0, 0, 6)
    slider.Position = UDim2.new(0, 0, 0.75, 0)
    slider.BackgroundColor3 = Color3.fromRGB(60,60,60)
    slider.BorderSizePixel = 0
    local sc = Instance.new("UICorner")
    sc.Parent = slider
    sc.CornerRadius = UDim.new(1,0)
    local fill = Instance.new("Frame")
    fill.Parent = slider
    fill.Size = UDim2.new((default-min)/(max-min), 0, 1, 0)
    fill.BackgroundColor3 = CONFIG.Accent
    fill.BorderSizePixel = 0
    local fc = Instance.new("UICorner")
    fc.Parent = fill
    fc.CornerRadius = UDim.new(1,0)
    local dragging = false
    local conn
    local function update(pos)
        local rel = math.clamp((pos.X - slider.AbsolutePosition.X) / slider.AbsoluteSize.X, 0, 1)
        local val = min + (max - min) * rel
        val = math.floor(val + 0.5)
        fill.Size = UDim2.new(rel, 0, 1, 0)
        valLabel.Text = tostring(val)
        if callback then callback(val) end
    end
    slider.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input.Position)
            conn = UIS.InputChanged:Connect(function(inp)
                if inp.UserInputType == Enum.UserInputType.MouseMovement then update(inp.Position) end
            end)
        end
    end)
    UIS.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 and dragging then
            dragging = false
            if conn then conn:Disconnect(); conn = nil end
        end
    end)
end

