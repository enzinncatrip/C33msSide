local function Notify(msg, dur, color)
    dur = dur or 3
    color = color or CONFIG.Accent
    local f = Instance.new("Frame")
    f.Parent = NotifyContainer
    f.Size = UDim2.new(1, 0, 0, 40)
    f.BackgroundColor3 = Color3.fromRGB(20,20,20)
    f.BorderSizePixel = 0
    f.Position = UDim2.new(0, 0, 0, -50)
    local fc = Instance.new("UICorner")
    fc.Parent = f
    fc.CornerRadius = UDim.new(0, 8)
    local fs = Instance.new("UIStroke")
    fs.Parent = f
    fs.Color = color
    fs.Thickness = 2
    local txt = Instance.new("TextLabel")
    txt.Parent = f
    txt.BackgroundTransparency = 1
    txt.Size = UDim2.new(1, -20, 1, 0)
    txt.Position = UDim2.new(0,10,0,0)
    txt.Text = msg
    txt.TextColor3 = Color3.new(1,1,1)
    txt.Font = Enum.Font.Gotham
    txt.TextSize = 16
    txt.TextXAlignment = Enum.TextXAlignment.Left
    txt.TextYAlignment = Enum.TextYAlignment.Center
    TweenService:Create(f, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Position = UDim2.new(0,0,0,0)}):Play()
    task.wait(0.1)
    for _, child in ipairs(NotifyContainer:GetChildren()) do
        if child ~= f then
            TweenService:Create(child, TweenInfo.new(0.3), {Position = UDim2.new(0,0,0, child.Position.Y.Offset + 45)}):Play()
        end
    end
    task.wait(dur)
    TweenService:Create(f, TweenInfo.new(0.3), {Position = UDim2.new(0,0,0,-50), BackgroundTransparency = 1, TextTransparency = 1}):Play()
    task.wait(0.4)
    f:Destroy()
    local children = NotifyContainer:GetChildren()
    for i, child in ipairs(children) do
        TweenService:Create(child, TweenInfo.new(0.3), {Position = UDim2.new(0,0,0,(i-1)*45)}):Play()
    end
end

