    title.Position = UDim2.new(0.04, 0, 0.02, 0)
    title.Text = tabName
    title.Font = Enum.Font.GothamBlack
    title.TextScaled = true
    title.TextColor3 = CONFIG.AccentLight
    title.TextXAlignment = Enum.TextXAlignment.Left

    local line = Instance.new("Frame")
    line.Parent = page
    line.Size = UDim2.new(0, 80, 0, 3)
    line.Position = UDim2.new(0.04, 0, 0.12, 0)
    line.BackgroundColor3 = CONFIG.Accent
    line.BorderSizePixel = 0
    local lineCorner = Instance.new("UICorner")
    lineCorner.Parent = line
    lineCorner.CornerRadius = UDim.new(1,0)

    local yOffset = 0.18

    -- ========== ABA INÍCIO ==========
    if tabName == "Início" then
        local desc = Instance.new("TextLabel")
        desc.Parent = page
        desc.BackgroundTransparency = 1
        desc.Size = UDim2.new(0.9, 0, 0, 200)
        desc.Position = UDim2.new(0.04, 0, 0.18, 0)
        desc.Text = "🐱 Bem-vindo ao MEGA POPCAT GUI v4.0!\n\n• Mais de 30 funcionalidades\n• Atalho F1 para abrir/fechar\n• Salvamento automático das configurações\n• Navegue pelas abas para explorar tudo!\n\nDivirta-se! 🎮"
        desc.TextColor3 = CONFIG.TextColor
        desc.Font = Enum.Font.Gotham
        desc.TextSize = 20
        desc.TextWrapped = true
        desc.TextXAlignment = Enum.TextXAlignment.Left

        CreateButton(page, "📢 Testar Notificação", function()
            Notify("🐱 Notificação de teste!", 3, CONFIG.Accent)
        end, 0.6)
    end

    -- ========== ABA PLAYER ==========
    if tabName == "Player" then
        local y = yOffset
        -- God Mode
        CreateToggle(page, "Modo Deus", false, function(state)
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                if state then
                    char.Humanoid.MaxHealth = 9e9
                    char.Humanoid.Health = 9e9
                else
                    char.Humanoid.MaxHealth = 100
                    char.Humanoid.Health = 100
                end
            end
        end, y)
        y = y + 0.12

        -- Infinite Jump
        CreateToggle(page, "Pulo Infinito", false, function(state)
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Jumping, state)
            end
        end, y)
        y = y + 0.12

        -- No Clip
        CreateToggle(page, "No Clip", false, function(state)
            local char = Player.Character
            if char then
                for _, part in ipairs(char:GetDescendants()) do
                    if part:IsA("BasePart") then
                        part.CanCollide = not state
                    end
                end
            end
        end, y)
        y = y + 0.12

        -- Fly
        CreateToggle(page, "Fly (Voo)", false, function(state)
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                local fly = Instance.new("BoolValue")
                fly.Name = "IsFlying"
                fly.Parent = char
                if state then
                    local bodyGyro = Instance.new("BodyGyro")
                    local bodyVelocity = Instance.new("BodyVelocity")
                    bodyGyro.P = 9e4
                    bodyGyro.D = 400
                    bodyGyro.MaxTorque = Vector3.new(9e9, 9e9, 9e9)
                    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
                    bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
                    bodyGyro.Parent = char.HumanoidRootPart
                    bodyVelocity.Parent = char.HumanoidRootPart
                    fly.Value = true
                    fly.Parent = char
                    local flyCon
                    flyCon = RunService.Heartbeat:Connect(function()
                        if not state or not char or not char.Parent then
                            flyCon:Disconnect()
                            return
                        end
                        local cam = workspace.CurrentCamera
                        local move = Vector3.new()
                        if UIS:IsKeyDown(Enum.KeyCode.W) then move = move + cam.CFrame.LookVector * 50 end
                        if UIS:IsKeyDown(Enum.KeyCode.S) then move = move - cam.CFrame.LookVector * 50 end
                        if UIS:IsKeyDown(Enum.KeyCode.A) then move = move - cam.CFrame.RightVector * 50 end
                        if UIS:IsKeyDown(Enum.KeyCode.D) then move = move + cam.CFrame.RightVector * 50 end
                        if UIS:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 50, 0) end
                        if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then move = move - Vector3.new(0, 50, 0) end
                        bodyVelocity.Velocity = move
                        bodyGyro.CFrame = cam.CFrame
                    end)
                    char:WaitForChild("IsFlying").Changed:Connect(function()
                        if not char.IsFlying.Value then
                            bodyGyro:Destroy()
                            bodyVelocity:Destroy()
                            fly:Destroy()
                            if flyCon then flyCon:Disconnect() end
                        end
                    end)
                else
                    if char:FindFirstChild("IsFlying") then
                        char.IsFlying.Value = false
                    end
                end
            end
        end, y)
        y = y + 0.12

        -- Sliders
        CreateSlider(page, "WalkSpeed", 16, 100, 16, function(val)
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.WalkSpeed = val
            end
        end, y)
        y = y + 0.14

        CreateSlider(page, "JumpPower", 50, 200, 50, function(val)
            local char = Player.Character
            if char and char:FindFirstChild("Humanoid") then
                char.Humanoid.JumpPower = val
            end
        end, y)
    end

    -- ========== ABA COMBATE ==========
    if tabName == "Combate" then
        local y = yOffset
        -- Kill All
        CreateButton(page, "💀 Matar Todos", function()
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= Player and plr.Character and plr.Character:FindFirstChild("Humanoid") then
                    plr.Character.Humanoid.Health = 0
                end
            end
            Notify("💀 Todos os inimigos eliminados!", 2, Color3.fromRGB(255,0,0))
        end, y, Color3.fromRGB(200,50,50))
        y = y + 0.12

        CreateButton(page, "🎯 Matar Mais Próximo", function()
            local nearest = nil
            local dist = math.huge
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= Player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                    local d = (plr.Character.HumanoidRootPart.Position - Player.Character.HumanoidRootPart.Position).Magnitude
                    if d < dist then
                        dist = d
                        nearest = plr
                    end
                end
            end
            if nearest and nearest.Character and nearest.Character:FindFirstChild("Humanoid") then
                nearest.Character.Humanoid.Health = 0
                Notify("🎯 Alvo eliminado!", 2, Color3.fromRGB(255,200,0))
            else
                Notify("❌ Nenhum alvo encontrado!", 2, Color3.fromRGB(255,0,0))
            end
        end, y, Color3.fromRGB(200,150,0))
        y = y + 0.12

        -- Aimbot simples (apenas mira)
        CreateToggle(page, "Aimbot (mirar)", false, function(state)
            -- Implementação básica: mira no inimigo mais próximo
            local aimCon
            if state then
                aimCon = RunService.Heartbeat:Connect(function()
                    local nearest = nil
                    local dist = math.huge
                    for _, plr in ipairs(Players:GetPlayers()) do
                        if plr ~= Player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                            local d = (plr.Character.HumanoidRootPart.Position - Player.Character.HumanoidRootPart.Position).Magnitude
                            if d < dist and d < 200 then
                                dist = d
                                nearest = plr
                            end
                        end
                    end
                    if nearest and nearest.Character and nearest.Character:FindFirstChild("HumanoidRootPart") then
                        local target = nearest.Character.HumanoidRootPart.Position + Vector3.new(0, 4, 0)
                        workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target)
                    end
                end)
            else
                if aimCon then aimCon:Disconnect() end
            end
        end, y)
        y = y + 0.12

        -- God Mode para todos (team)
        CreateToggle(page, "Deus para Time", false, function(state)
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr.Team == Player.Team then
                    local char = plr.Character
                    if char and char:FindFirstChild("Humanoid") then
                        if state then
                            char.Humanoid.MaxHealth = 9e9
                            char.Humanoid.Health = 9e9
                        else
                            char.Humanoid.MaxHealth = 100
                            char.Humanoid.Health = 100
                        end
                    end
                end
            end
        end, y)
    end

    -- ========== ABA TELEPORTES ==========
    if tabName == "Teleportes" then
        local y = yOffset
        local teleports = {
            {"🏠 Spawn", Vector3.new(0, 5, 0)},
            {"🏪 Loja", Vector3.new(100, 5, 100)},
            {"⚔️ Arena", Vector3.new(-150, 5, -150)},
            {"🌳 Parque", Vector3.new(200, 5, 200)},
            {"🏖️ Praia", Vector3.new(-200, 5, 200)},
        }
        for _, data in ipairs(teleports) do
            CreateButton(page, data[1], function()
                if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                    Player.Character.HumanoidRootPart.CFrame = CFrame.new(data[2])
                end
            end, y, Color3.fromRGB(70,150,255))
            y = y + 0.12
        end
        -- Teleport para posição customizada (slider de coordenadas?)
        -- Vou colocar um botão para teleportar para a posição do mouse
        CreateButton(page, "📍 Teleportar para Mouse", function()
            local mouse = Player:GetMouse()
            if mouse and mouse.Hit then
                if Player.Character and Player.Character:FindFirstChild("HumanoidRootPart") then
                    Player.Character.HumanoidRootPart.CFrame = CFrame.new(mouse.Hit.Position + Vector3.new(0,3,0))
                end
            end
        end, y, Color3.fromRGB(255,200,100))
    end

    -- ========== ABA VISUAIS ==========
    if tabName == "Visuais" then
        local y = yOffset
        -- ESP simples (nome e caixa)
        CreateToggle(page, "ESP (nome)", false, function(state)
            -- Implementação simples: cria billboards em todos os jogadores
            if state then
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr ~= Player then
                        local char = plr.Character
                        if char then
                            local bbg = Instance.new("BillboardGui")
                            bbg.Name = "ESP_Name"
                            bbg.Parent = char.HumanoidRootPart
                            bbg.Size = UDim2.new(0, 200, 0, 40)
                            bbg.Adornee = char.HumanoidRootPart
                            local label = Instance.new("TextLabel")
                            label.Parent = bbg
                            label.Size = UDim2.new(1,0,1,0)
                            label.BackgroundTransparency = 1
                            label.Text = plr.Name
                            label.TextColor3 = plr.Team and plr.Team.TeamColor.Color or Color3.new(1,1,1)
                            label.Font = Enum.Font.GothamBold
                            label.TextSize = 18
                            bbg.AlwaysOnTop = true
                            plr.CharacterAdded:Connect(function(newChar)
                                task.wait(0.5)
                                if state then
                                    local newBbg = bbg:Clone()
                                    newBbg.Parent = newChar.HumanoidRootPart
                                    newBbg.Adornee = newChar.HumanoidRootPart
                                end
                            end)
                        end
                    end
                end
            else
                for _, plr in ipairs(Players:GetPlayers()) do
                    if plr.Character then
                        for _, child in ipairs(plr.Character:GetDescendants()) do
                            if child:IsA("BillboardGui") and child.Name == "ESP_Name" then
                                child:Destroy()
                            end
                        end
                    end
                end
            end
        end, y)
        y = y + 0.12

        -- Chams (cores vibrantes)
        CreateToggle(page, "Chams (inimigos)", false, function(state)
            for _, plr in ipairs(Players:GetPlayers()) do
                if plr ~= Player and plr.Character then
                    for _, part in ipairs(plr.Character:GetDescendants()) do
                        if part:IsA("BasePart") then
                            if state then
                                local highlight = Instance.new("Highlight")
                                highlight.Parent = part
                                highlight.FillColor = Color3.fromRGB(255,0,0)
                                highlight.OutlineColor = Color3.fromRGB(255,255,255)
                                highlight.FillTransparency = 0.3
                            else
                                for _, h in ipairs(part:GetChildren()) do
                                    if h:IsA("Highlight") then h:Destroy() end
                                end
                            end
                        end
                    end
                end
            end
        end, y)
        y = y + 0.12

        -- Alterar cor do céu
        CreateSlider(page, "Fog (névoa)", 0, 100, 0, function(val)
            game.Lighting.FogEnd = 100 + val * 10
            game.Lighting.FogStart = 50 + val * 5
        end, y)
        y = y + 0.14

        -- Tema claro/escuro
        CreateToggle(page, "Tema Claro", LoadSetting("Tema Claro", false), function(state)
            local bg = state and Color3.fromRGB(230,230,240) or CONFIG.BG
            local sidebar = state and Color3.fromRGB(200,200,210) or CONFIG.SidebarBG
            local top = state and Color3.fromRGB(210,210,220) or CONFIG.TopBG
            local content = state and Color3.fromRGB(240,240,250) or CONFIG.ContentBG
            local text = state and Color3.fromRGB(30,30,40) or CONFIG.TextColor
            Main.BackgroundColor3 = bg
            Sidebar.BackgroundColor3 = sidebar
            Top.BackgroundColor3 = top
            Content.BackgroundColor3 = content
            -- Atualizar todos os textos
            for _, page in ipairs(Content:GetChildren()) do
                if page:IsA("Frame") then
                    for _, child in ipairs(page:GetDescendants()) do
                        if child:IsA("TextLabel") or child:IsA("TextButton") then
                            if child ~= Title then
                                child.TextColor3 = text
                            end
                        end
                    end
                end
            end
            Title.TextColor3 = state and Color3.fromRGB(50,50,80) or CONFIG.AccentLight
            SaveSetting("Tema Claro", state)
            Notify("Tema " .. (state and "Claro" or "Escuro") .. " aplicado!", 2)
        end, y)
    end

    -- ========== ABA CONFIG ==========
    if tabName == "Config" then
        local y = yOffset
        CreateButton(page, "🔄 Resetar Configurações", function()
            Settings = {}
            getgenv().PopcatSettings = {}
            Notify("🔄 Configurações resetadas!", 2, Color3.fromRGB(255,200,0))
        end, y, Color3.fromRGB(200,100,0))
        y = y + 0.12

        CreateButton(page, "💾 Salvar Configurações", function()
            Notify("💾 Configurações salvas (automaticamente!)", 2, Color3.fromRGB(0,200,100))
        end, y, Color3.fromRGB(0,150,100))
        y = y + 0.12

        local label = Instance.new("TextLabel")
        label.Parent = page
        label.BackgroundTransparency = 1
        label.Size = UDim2.new(0.9, 0, 0, 120)
        label.Position = UDim2.new(0.04, 0, y, 0)
        label.Text = "⚙️ Configurações Gerais\n\n• Atalho: F1\n• Todas as preferências são salvas automaticamente\n• Se algo não funcionar, reinicie o jogo e recarregue a GUI"
        label.TextColor3 = CONFIG.TextColor
        label.Font = Enum.Font.Gotham
        label.TextSize = 18
        label.TextWrapped = true
        label.TextXAlignment = Enum.TextXAlignment.Left
    end

    -- ========== ABA SOBRE ==========
    if tabName == "Sobre" then
        local label = Instance.new("TextLabel")
        label.Parent = page
        label.BackgroundTransparency = 1
        label.Size = UDim2.new(0.9, 0, 0, 300)
        label.Position = UDim2.new(0.04, 0, 0.18, 0)
        label.Text = "🐱 MEGA POPCAT GUI v4.0\n\nCriado por enzinncatrip\n\n💡 Funcionalidades:\n• Player: Deus, Pulo Infinito, No Clip, Fly, Sliders\n• Combate: Matar Todos, Matar Mais Próximo, Aimbot\n• Teleportes: Spawn, Loja, Arena, etc.\n• Visuais: ESP, Chams, Controle de Névoa, Tema\n• Config: Resetar/Salvar configurações\n\n📌 Obrigado por usar! ❤️"
        label.TextColor3 = CONFIG.TextColor
        label.Font = Enum.Font.Gotham
        label.TextSize = 19
        label.TextWrapped = true
        label.TextXAlignment = Enum.TextXAlignment.Left
    end

    Pages[tabName] = page
    return page
end

